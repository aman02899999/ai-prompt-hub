---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-columns">
		<div>
			<p class="brand">AI Prompt Hub</p>
			<p>Curated AI prompt templates, workflow guides, and content systems to help teams work smarter.</p>
		</div>
		<div>
			<p class="footer-heading">Explore</p>
			<nav>
				<a href="/blog">Blog</a>
				<a href="/about">About</a>
				<a href="/contact">Contact</a>
				<a href="/privacy">Privacy</a>
				<a href="/terms">Terms</a>
			</nav>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {year} AI Prompt Hub. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		padding: 3rem 1rem 4rem;
		background: #0f172a;
		color: #d8e3ff;
	}
	.footer-columns {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 2rem;
		max-width: 1080px;
		margin: auto;
	}
	.brand {
		font-size: 1.05rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}
	.footer-heading {
		margin: 0 0 0.75rem;
		font-size: 0.95rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}
	nav {
		display: grid;
		gap: 0.6rem;
	}
	a {
		color: #d8e3ff;
		text-decoration: none;
	}
	a:hover {
		color: white;
	}
	.footer-bottom {
		margin-top: 2rem;
		text-align: center;
		color: rgb(var(--gray-light));
	}
	@media (max-width: 720px) {
		.footer-columns {
			grid-template-columns: 1fr;
		}
	}
</style>
