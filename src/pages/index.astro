---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import AdsensePlaceholder from '../components/AdsensePlaceholder.astro';
import { SITE_CATEGORIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">AI Prompt Hub</p>
					<h1>Prompt templates and workflows for smarter AI results.</h1>
					<p>
						Find curated AI prompt ideas, ready-to-use templates, and workflow guides for marketing,
						SEO, business, development, video, and productivity.
					</p>
				</div>
				<div class="hero-actions">
					<a class="button" href="/blog">Browse prompts</a>
					<a class="button secondary" href="/about">Learn more</a>
				</div>
			</section>

			<section class="search-card">
				<h2>Search prompt guides</h2>
				<p>Find a template for your next AI session by keyword, category, or outcome.</p>
				<form action="/blog" method="get">
					<input type="search" name="q" placeholder="Search prompts, marketing ideas, SEO examples..." />
					<button type="submit">Search</button>
				</form>
			</section>

			<section class="featured-categories">
				<h2>Featured categories</h2>
				<div class="card-grid">
					{SITE_CATEGORIES.map((category) => (
						<article class="category-card" key={category.title}>
							<h3>{category.title}</h3>
							<p>{category.description}</p>
						</article>
					))}
				</div>
			</section>

			<AdsensePlaceholder />

			<section class="latest-articles">
				<div class="section-header">
					<h2>Latest articles</h2>
					<a href="/blog">View all posts</a>
				</div>
				<div class="card-grid">
					{posts.map((post) => (
						<article class="article-card" key={post.id}>
							<a href={`/blog/${post.id}/`}>
								<p class="meta-badge">{post.data.category}</p>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
							<p class="article-date"><FormattedDate date={post.data.pubDate} /></p>
						</article>
					))}
				</div>
			</section>

			<section class="newsletter-card">
				<h2>Join the newsletter</h2>
				<p>Receive AI prompt updates, new article releases, and workflow inspiration once a month.</p>
				<form action="mailto:newsletter@ai-prompt-hub.com" method="post" encType="text/plain">
					<input type="email" name="email" placeholder="Enter your email" />
					<button type="submit">Subscribe</button>
				</form>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1180px;
	}
	.hero {
		display: grid;
		grid-template-columns: 1.8fr 1fr;
		align-items: center;
		gap: 2rem;
		margin-bottom: 3.5rem;
	}
	.eyebrow {
		font-size: 0.82rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--accent);
		margin-bottom: 1rem;
	}
	h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.8rem, 5vw, 4.5rem);
		line-height: 1.02;
	}
	.hero-copy p {
		max-width: 50rem;
		font-size: 1.1rem;
		line-height: 1.8;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1rem 1.8rem;
		border-radius: 999px;
		background: var(--accent);
		color: white;
		font-weight: 700;
		text-decoration: none;
	}
	.button.secondary {
		background: rgb(var(--gray-light));
		color: rgb(var(--black));
	}
	.search-card,
	.newsletter-card,
	.featured-categories,
	.latest-articles {
		margin-bottom: 2.5rem;
		padding: 2rem;
		background: white;
		border-radius: 28px;
		box-shadow: var(--box-shadow);
	}
	.search-card form,
	.newsletter-card form {
		display: grid;
		gap: 1rem;
		margin-top: 1rem;
	}
	.search-card input,
	.newsletter-card input {
		width: 100%;
		padding: 1rem 1.2rem;
		border-radius: 14px;
		border: 1px solid rgb(var(--gray-light));
		background: rgb(var(--gray-light));
	}
	.search-card button,
	.newsletter-card button {
		width: fit-content;
		padding: 1rem 1.5rem;
		border: none;
		border-radius: 999px;
		background: var(--accent);
		color: white;
		font-weight: 700;
		cursor: pointer;
	}
	.card-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}
	.category-card,
	.article-card {
		padding: 1.75rem;
		border-radius: 24px;
		border: 1px solid rgb(var(--gray-light));
		background: white;
	}
	.category-card h3,
	.article-card h3 {
		margin-top: 0;
	}
	.meta-badge {
		display: inline-block;
		margin-bottom: 0.8rem;
		padding: 0.35rem 0.9rem;
		border-radius: 999px;
		background: rgba(35, 55, 255, 0.1);
		color: var(--accent);
		font-size: 0.9rem;
		font-weight: 700;
	}
	.article-card p {
		margin: 0.75rem 0 0;
	}
	.article-date {
		margin-top: 1rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
	}
	.section-header a {
		color: var(--accent);
		text-decoration: none;
		font-weight: 700;
	}
	@media (max-width: 980px) {
		.hero,
		.card-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
